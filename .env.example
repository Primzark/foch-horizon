VITE_PUBLIC_SITE_URL=https://fochimmobilier.lovable.app
VITE_API_MODE=mock
VITE_API_BASE_URL=
VITE_CHATBOT_ENABLE_EDGE_RAG=false
VITE_CHATBOT_ROUTER_V2=true
VITE_CHATBOT_ENABLE_EDGE_AGENT_TOOLS=false

# Optional local dev proxy to call Supabase Edge Functions while keeping frontend /api/* paths unchanged
# Set VITE_API_MODE=edge and VITE_API_BASE_URL=http://localhost:8080 when using Vite dev server proxy
# Set VITE_CHATBOT_ENABLE_EDGE_RAG=true to let website-content questions hit the edge chatbot (RAG) instead of local-only replies
# Set VITE_CHATBOT_ENABLE_EDGE_AGENT_TOOLS=true to route property search/compare/handoff flows to the edge tool assistant
# VITE_SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=your_public_anon_key

# Server-side / indexing (do NOT expose in frontend runtime)
# GEMINI_API_KEY=your_server_gemini_key
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# CHATBOT_LLM_PROVIDER=gemini
# CHATBOT_EMBEDDING_PROVIDER=gemini
# RAG_EMBEDDING_PROVIDER=gemini
# OPENAI_API_KEY=optional_openai_key
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# CHATBOT_RAG_ENABLED=true
# CHATBOT_RAG_MATCH_COUNT=6
# CHATBOT_RAG_MATCH_THRESHOLD=0.70
# CHATBOT_RAG_HYBRID_ENABLED=true
# CHATBOT_RAG_VECTOR_MATCH_COUNT=10
# CHATBOT_RAG_KEYWORD_MATCH_COUNT=12
# CHATBOT_RAG_RERANK_TOP_N=8
# CHATBOT_RAG_CONTEXT_TOP_N=5
# CHATBOT_RAG_HYBRID_VECTOR_WEIGHT=0.55
# CHATBOT_RAG_HYBRID_KEYWORD_WEIGHT=0.30
# CHATBOT_RAG_MAX_CONTEXT_CHARS=5200
# CHATBOT_RAG_EMBEDDING_DIMENSION=1536
# CHATBOT_AGENT_TOOLS_ENABLED=false
# CHATBOT_AGENT_TOOLS_MAX_RESULTS=5
# CHATBOT_AGENT_TOOLS_COMPARE_LIMIT=3
# CHATBOT_GEMINI_PLANNER_ENABLED=false
# CHATBOT_GEMINI_PLANNER_MODEL=gemini-2.5-flash-lite
# CHATBOT_GEMINI_PLANNER_TIMEOUT_MS=1800
# CHATBOT_GEMINI_PLANNER_INCLUDE_HISTORY_TURNS=4
# CHATBOT_GEMINI_PLANNER_MAX_QUESTION_CHARS=700
# CHATBOT_GEMINI_PLANNER_TEMPERATURE=0
# SUPABASE_URL=https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# RAG_INDEX_BASE_URL=https://fochimmobilier.lovable.app
# RAG_INDEX_RENDER_MODE=http
# RAG_INDEX_RENDER_WAIT_MS=1000
# RAG_EMBEDDING_OUTPUT_DIMENSION=1536

# Integration test env examples (only used when running edge integration tests)
# RUN_EDGE_INTEGRATION=true
# RUN_EDGE_WRITE_TESTS=false
# EDGE_API_BASE_URL=https://your-edge-host
# EDGE_CITIES_URL=https://your-edge-host/api/cities
# EDGE_PROPERTIES_URL=https://your-edge-host/api/properties
# EDGE_LEADS_URL=https://your-edge-host/api/leads
# EDGE_ANON_KEY=your_public_anon_key
