VITE_PUBLIC_SITE_URL=https://fochimmobilier.lovable.app
VITE_API_MODE=mock
VITE_API_BASE_URL=

# Optional local dev proxy to call Supabase Edge Functions while keeping frontend /api/* paths unchanged
# Set VITE_API_MODE=edge and VITE_API_BASE_URL=http://localhost:8080 when using Vite dev server proxy
# VITE_SUPABASE_PROJECT_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=your_public_anon_key

# Integration test env examples (only used when running edge integration tests)
# RUN_EDGE_INTEGRATION=true
# RUN_EDGE_WRITE_TESTS=false
# EDGE_API_BASE_URL=https://your-edge-host
# EDGE_CITIES_URL=https://your-edge-host/api/cities
# EDGE_PROPERTIES_URL=https://your-edge-host/api/properties
# EDGE_LEADS_URL=https://your-edge-host/api/leads
# EDGE_ANON_KEY=your_public_anon_key
